# Copy this file to local.properties and fill in your values.
# local.properties is in .gitignore. Never commit secrets.

# Path to Android SDK. Android Studio usually writes this automatically.
sdk.dir=C\:\\Users\\YOURNAME\\AppData\\Local\\Android\\Sdk

# Backend
# Where the Duddy FastAPI backend lives.
# - Android emulator: http://10.0.2.2:8010 reaches your localhost.
# - Physical phone over USB: run `adb reverse tcp:8010 tcp:8010` and use http://127.0.0.1:8010.
# - Physical phone over Wi-Fi: use your LAN IP, e.g. http://192.168.1.42:8010.
# - Production: https://api.duddy.app
DUDDY_BACKEND_URL=http://10.0.2.2:8010

# Supabase
# From your Supabase project: Settings > API.
# The anon key is safe to embed in mobile apps when Row Level Security policies protect data.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_anon_key_here
