# ── Supabase ───────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...                # server-only — DO NOT expose to client
SUPABASE_JWT_SECRET=...                    # Settings → API → JWT Secret

# ── OpenAI ─────────────────────────────────────────────────────────────────
AI_PROVIDER=openai
COACH_PROVIDER=openai                      # openai | xai | local
SPEECH_TO_TEXT_PROVIDER=openai             # openai | xai
PRONUNCIATION_PROVIDER=azure               # azure | openai | xai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini                   # cost-efficient default
OPENAI_COACH_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_MAX_OUTPUT_TOKENS=300

# xAI / Grok (optional second provider)
XAI_API_KEY=xai-...
XAI_MODEL=grok-4.3
XAI_COACH_MODEL=grok-4.3

# ── Azure Speech (Pronunciation Assessment) ────────────────────────────────
# Create a "Speech" resource in Azure portal — F0 free tier gives 5 hr/mo free
AZURE_SPEECH_KEY=...
AZURE_SPEECH_REGION=eastus

# ── Redis (recommended for production) ─────────────────────────────────────
# Free option: https://upstash.com — 10K commands/day free
REDIS_URL=redis://default:PASS@your-host:6379

# ── Misc ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:*,https://duddy.app
MONTHLY_BUDGET_USD=500
JWT_AUDIENCE=authenticated
DEV_AUTH_BYPASS=false                      # true only for local backend testing without Supabase
PORT=8000
